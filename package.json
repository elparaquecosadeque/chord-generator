{
  "name": "neon-chord-finder",
  "version": "0.1.0",
  "description": "Angular vertical slice for searching guitar chords by name and rendering SVG diagrams from chords-db.",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "test": "ng test --watch=false --browsers=ChromeHeadless",
    "build": "ng build",
    "build:gh-pages": "ng build --base-href /chord-generator/"
  },
  "private": true,
  "dependencies": {
    "@angular/common": "22.0.4",
    "@angular/compiler": "22.0.4",
    "@angular/core": "22.0.4",
    "@angular/forms": "22.0.4",
    "@angular/platform-browser": "22.0.4",
    "@tombatossals/chords-db": "0.5.1",
    "rxjs": "~7.8.0",
    "tslib": "^2.8.1",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular/build": "22.0.4",
    "@angular/cli": "22.0.4",
    "@angular/compiler-cli": "22.0.4",
    "@types/jasmine": "^6.0.0",
    "istanbul-lib-instrument": "^6.0.3",
    "jasmine-core": "^6.3.0",
    "karma": "^6.4.4",
    "karma-chrome-launcher": "^3.2.0",
    "karma-coverage": "^2.2.1",
    "karma-jasmine": "^5.1.0",
    "karma-jasmine-html-reporter": "^2.2.0",
    "typescript": "~6.0.3"
  }
}